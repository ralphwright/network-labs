# Database
POSTGRES_DB=network_labs
POSTGRES_USER=labuser
POSTGRES_PASSWORD=labpassword
POSTGRES_HOST=db
POSTGRES_PORT=5432
# DATABASE_URL is constructed from the variables above — keep all values in sync
DATABASE_URL=postgresql+asyncpg://labuser:labpassword@db:5432/network_labs

# Backend
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=INSECURE-CHANGE-THIS-IN-PRODUCTION-generate-a-random-64-hex-char-string
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
DEBUG=true

# Frontend
VITE_API_URL=http://localhost:8000
VITE_WS_URL=ws://localhost:8000

# CORS
CORS_ORIGINS=http://localhost:3000,http://localhost:5173
